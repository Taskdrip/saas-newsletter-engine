# ──────────────────────────────────────────────────────────────
# listmonk environment variables
# Copy this file to .env for local Docker Compose development.
# In Railway, set these as Service Variables in the dashboard.
# ──────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Railway PostgreSQL addon sets DATABASE_URL automatically.
# For local dev with docker-compose, set manually:
DATABASE_URL=postgresql://listmonk:listmonk@db:5432/listmonk

# SSL mode for DB connection.
# Use "require" on Railway (default). Use "disable" for local Docker Compose.
DB_SSLMODE=require

# ── listmonk admin credentials ────────────────────────────────
# These become the username/password for the /admin UI.
# Change from defaults before deploying!
LISTMONK_ADMIN_USER=listmonk
LISTMONK_ADMIN_PASSWORD=your_strong_password_here

# ── First-boot install ────────────────────────────────────────
# Set to "true" on the FIRST deploy only, to create DB tables.
# Remove or set to "false" for all subsequent deploys.
LISTMONK_INSTALL=true

# ── Schema upgrades ───────────────────────────────────────────
# Runs safe DB migrations on every boot (no-op if already current).
# Leave as "true" (default) unless you have a specific reason not to.
LISTMONK_UPGRADE=true

# ── Railway internal ─────────────────────────────────────────
# Railway injects PORT automatically — do not set this manually on Railway.
# For local docker-compose it is set inside docker-compose.yml.
# PORT=9000
